<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zmbdp.chat.service.mapper.SysAiFeedbackMapper">

    <!-- 按反馈类型统计数量 -->
    <select id="countByType" resultType="java.lang.Long">
        SELECT COUNT(*)
        FROM sys_ai_feedback
        WHERE feedback_type = #{feedbackType}
    </select>

    <!-- 统计反馈总数 -->
    <select id="countTotalFeedback" resultType="java.lang.Long">
        SELECT COUNT(*)
        FROM sys_ai_feedback
    </select>

    <!-- 统计反馈用户数（按 user_id 去重） -->
    <select id="countFeedbackUsers" resultType="java.lang.Long">
        SELECT COUNT(DISTINCT user_id)
        FROM sys_ai_feedback
    </select>

    <!-- 按点踩原因分组统计分布 -->
    <select id="countDislikeReasonDistribution" resultType="java.util.Map">
        SELECT
            dislike_reason AS reason,
            COUNT(*) AS count
        FROM sys_ai_feedback
        WHERE feedback_type = 'DISLIKE'
          AND dislike_reason IS NOT NULL
          AND dislike_reason != ''
        GROUP BY dislike_reason
        ORDER BY count DESC
    </select>

</mapper>
