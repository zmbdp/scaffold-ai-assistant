# 自动处理文本文件换行符
* text=auto

# Shell 脚本强制使用 LF（Linux 必须）
*.sh text eol=lf
*.bash text eol=lf

# Windows 批处理保持 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# 二进制文件不处理
*.jar binary
*.zip binary
*.tgz binary
*.png binary
*.jpg binary

target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

